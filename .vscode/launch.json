{
   // Use IntelliSense to learn about possible attributes.
   // Hover to view descriptions of existing attributes.
   // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
   "version": "0.2.0",
   "configurations": [
      {
         "name": "(gdb) Launch",
         "type": "cppdbg",
         "request": "launch",
         "program": "${workspaceFolder}/deepthought",
         "args": [
            "-d",
            "Missions/DSM_DEMO",
            "-o",
            "Missions/DSM_DEMO/blah",
            "-g",
            "0",
         ],
         "stopAtEntry": false,
         "cwd": "${workspaceFolder}",
         "environment": [],
         "externalConsole": false,
         "MIMode": "gdb",
         "preLaunchTask": "make project",
         "setupCommands": [
            {
               "description": "Enable pretty-printing for gdb",
               "text": "-enable-pretty-printing",
               "ignoreFailures": true
            },
            {
               "description": "Set Disassembly Flavor to Intel",
               "text": "-gdb-set disassembly-flavor intel",
               "ignoreFailures": true
            }
         ]
      },
      {
         "name": "(gdb) Deploy",
         "type": "cppdbg",
         "request": "launch",
         "program": "${workspaceFolder}/deepthought",
         "args": [
            "-d",
            "Missions/DSM_DEMO",
            "-o",
            "Missions/DSM_DEMO/blah",
            "-g",
            "0",
         ],
         "stopAtEntry": false,
         "cwd": "${workspaceFolder}",
         "environment": [],
         "externalConsole": false,
         "MIMode": "gdb",
         "preLaunchTask": "make project opt",
         "setupCommands": [
            {
               "description": "Enable pretty-printing for gdb",
               "text": "-enable-pretty-printing",
               "ignoreFailures": true
            },
            {
               "description": "Set Disassembly Flavor to Intel",
               "text": "-gdb-set disassembly-flavor intel",
               "ignoreFailures": true
            }
         ]
      },
      {
         "name": "(gdb) Profile",
         "type": "cppdbg",
         "request": "launch",
         "program": "/usr/bin/valgrind",
         "args": [
            "--tool=callgrind",
            "${workspaceFolder}/deepthought",
            "-d",
            "${workspaceFolder}/Missions/simple_mission/",
            "-o",
            "${workspaceFolder}/Missions/simple_mission/blah",
            "-g",
            "0"
         ],
         "stopAtEntry": false,
         "cwd": "${workspaceFolder}",
         "environment": [
            {
               "name": "LD_PROFILE_OUTPUT",
               "value": "${config:LD_PROFILE_OUTPUT}"
            },
            {
               "name": "LD_PROFILE",
               "value": "${config:LD_PROFILE}"
            }
         ],
         "externalConsole": false,
         "MIMode": "gdb",
         "preLaunchTask": "profile build project",
         "setupCommands": [
            {
               "description": "Enable pretty-printing for gdb",
               "text": "-enable-pretty-printing",
               "ignoreFailures": true
            },
            {
               "description": "Set Disassembly Flavor to Intel",
               "text": "-gdb-set disassembly-flavor intel",
               "ignoreFailures": true
            },
         ]
      },
      {
         "name": "(gdb) Test",
         "type": "cppdbg",
         "request": "launch",
         "program": "${workspaceFolder}/Test",
         "stopAtEntry": false,
         "cwd": "${workspaceFolder}",
         "environment": [],
         "externalConsole": false,
         "MIMode": "gdb",
         "preLaunchTask": "test project",
         "setupCommands": [
            {
               "description": "Enable pretty-printing for gdb",
               "text": "-enable-pretty-printing",
               "ignoreFailures": true
            },
            {
               "description": "Set Disassembly Flavor to Intel",
               "text": "-gdb-set disassembly-flavor intel",
               "ignoreFailures": true
            }
         ]
      },
      {
         "name": "(gdb) Debug",
         "type": "cppdbg",
         "request": "launch",
         "program": "${workspaceFolder}/deepthought",
         "args": [
            "-d",
            "${workspaceFolder}/Missions/DSM_DEMO/",
            "-o",
            "${workspaceFolder}/Missions/DSM_DEMO/blah",
            "-g",
            "1"
         ],
         "stopAtEntry": false,
         "cwd": "${workspaceFolder}",
         "environment": [],
         "externalConsole": false,
         "MIMode": "gdb",
         "preLaunchTask": "profile build project",
         "setupCommands": [
            {
               "description": "Enable pretty-printing for gdb",
               "text": "-enable-pretty-printing",
               "ignoreFailures": true
            },
            {
               "description": "Set Disassembly Flavor to Intel",
               "text": "-gdb-set disassembly-flavor intel",
               "ignoreFailures": true
            }
         ]
      }
   ]
}