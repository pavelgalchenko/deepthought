{
    "version": "2.0.0",
    "command": "bash",
    "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
    },
    "options": {
        "cwd": "${workspaceRoot}",
        "environment": [],
    },
    "args": [
        "-c"
    ],
    "tasks": [
        {
            "label": "make project",
            "type": "shell",
            "group": "build",
            "args": [
                "make",
                "clean",
                "--build"
            ]
        },
        {
            "label": "make project opt",
            "type": "shell",
            "group": "build",
            "args": [
                "make",
                "clean",
                "--build"
            ]
        },
        {
            "label": "profile build project",
            "type": "shell",
            "group": "build",
            "args": [
                "cmake",
                "-DCMAKE_BUILD_TYPE=DEBUG",
                // "-DCMAKE_CXX_FLAGS=-pg",
                // "-DCMAKE_EXE_LINKER_FLAGS=-pg",
                // "-DCMAKE_SHARED_LINKER_FLAGS=-pg",
                // "-S",
                // "-B",
                "${workspaceFolder}",
                "&&",
                "make",
                "-j"
                // "--build"
            ]
        },
        {
            "label": "analyze project",
            "type": "shell",
            "args": [
                "echo",
                "${env:LD_PROFILE}",
                "&&",
                "gprof",
                "./deepthought",
                "gmon.out",
                ">",
                "dt_analysis.txt",
                "&&",
                "sprof",
                "./Kit/${config:LD_PROFILE}",
                "${config:LD_PROFILE}.profile",
                ">",
                "kit_analysis.txt"
            ]
        },
        {
            "label": "test project",
            "type": "shell",
            "group": "build",
            "args": [
                "make",
                "clean",
                "&&",
                "make",
                "-j",
                "Test",
                "GUIFLAG="
            ]
        },
    ]
}